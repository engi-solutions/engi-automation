# Blacklist approach: allow everything except build artifacts and dev files
# This is needed for the multi-stage Dockerfile that builds from source.
#
# The original n8n .dockerignore used a whitelist (allow only compiled/) because
# their pipeline builds outside Docker. Our fork builds inside Docker.

# Git
.git
.gitignore

# Build artifacts (we build fresh inside Docker)
compiled/
dist/

# Node modules (pnpm install runs inside Docker)
node_modules/
**/node_modules/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Dev containers
.devcontainer/

# Test coverage
coverage/
**/coverage/

# Environment files (secrets must not be baked into images)
.env
.env.*
!.env.example

# CI config (not needed for build)
.github/
!.github/scripts/trim-fe-packageJson.js

# Docker images for official n8n (we use root Dockerfile instead)
# Keep docker/images/n8n/docker-entrypoint.sh (needed by runtime stage)
